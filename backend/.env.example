# NVAI backend env template — copy to .env locally
# Supabase (Postgres)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Dropbox Sign (DDNDA legal)
DROPBOX_SIGN_API_KEY=
DDNDA_TEMPLATE_ID=

# Anthropic (Bernard)
ANTHROPIC_API_KEY=

# ElevenLabs (Bernard voice + audiobook)
ELEVENLABS_API_KEY=

# Higgsfield (video generation)
HIGGSFIELD_API_KEY=

# Meshy.ai (3D model generation)
MESHY_API_KEY=

# Porkbun API (domain DNS management)
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# Cloudflare R2 (object storage for videos)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_TOKEN=

# Railway (FastAPI backend deploy)
RAILWAY_PROJECT_ID=
RAILWAY_TOKEN=
